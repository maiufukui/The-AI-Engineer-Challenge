# FastAPI base URL (server-side only). Next.js POST /api/chat proxies here.
# Local dev: default is http://127.0.0.1:8000 if you omit this.
# BACKEND_URL=http://127.0.0.1:8000

# Optional: skip the proxy and call FastAPI from the browser (must be a public
# HTTPS URL on production to avoid mixed-content blocks).
# NEXT_PUBLIC_API_URL=https://your-api.example.com
